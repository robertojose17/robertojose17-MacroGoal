{
  "expo": {
    "name": "Macro Goal",
    "slug": "macro-goal",
    "version": "1.3.1",
    "orientation": "portrait",
    "icon": "./assets/images/72ae1849-bd62-45ba-89bf-c2232486e3a0.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/72ae1849-bd62-45ba-89bf-c2232486e3a0.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "5",
      "bundleIdentifier": "com.robertojose17.macrogoal",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSSpeechRecognitionUsageDescription": "We need access to speech recognition to transcribe your voice input for the AI meal estimator",
        "NSPhotoLibraryUsageDescription": "Elite Macro Tracker needs access to your photo library to let you select progress photos for your weight check-ins. For example, you can choose a photo from your gallery to track your body transformation over time alongside your weight measurements."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/72ae1849-bd62-45ba-89bf-c2232486e3a0.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "versionCode": 3,
      "package": "com.robertojose17.macrogoal",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/72ae1849-bd62-45ba-89bf-c2232486e3a0.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Elite Macro Tracker to access your camera for barcode scanning"
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Elite Macro Tracker to access your microphone for voice input"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Elite Macro Tracker needs access to your photo library to let you select progress photos for your weight check-ins. For example, you can choose a photo from your gallery to track your body transformation over time alongside your weight measurements."
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-5592015069000241~5529470607",
          "iosAppId": "ca-app-pub-5592015069000241~5529470607"
        }
      ],
      "@bacons/apple-targets",
      "expo-secure-store"
    ],
    "scheme": "macrogoal",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
